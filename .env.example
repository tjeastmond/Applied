# what port should APPLIED run on locally?
PORT=3030

# either sqlite or turso
DATABASE_PROVIDER=sqlite

# sqlite db file path
DATABASE_PATH=data/applied.db

# host sqlite alternative
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# for your personal workflows
AGENT_API_TOKEN=

# local file logging (disable on Vercel until remote shipping exists)
LOG_ENABLED=true
LOG_LEVEL=info
LOG_DIR=data/logs
LOG_FILE=applied.log
LOG_MAX_SIZE=5m
LOG_MAX_FILES=7
